# ============================================================
# TVA Workshop — Environment Variables
# Copy this file to .env and fill in your values
# Values marked AUTO are populated by deploy.ps1 / setup-entra-apps.ps1
# ============================================================

# --- Azure OpenAI / AI Foundry (Lab 1) ---
AZURE_OPENAI_ENDPOINT=https://tva-workshop.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Azure AI Search (Lab 1) ---
AZURE_SEARCH_ENDPOINT=https://tva-workshop-search.search.windows.net
AZURE_SEARCH_KEY=

# --- MCP Server (boilerplate/mcp-backend) ---
MCP_REQUIRE_AUTH=true
MCP_PRM_METADATA_PATH=prm_metadata.json
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_SCHEME=https

# --- OAuth / Entra ID (AUTO — set by setup-entra-apps.ps1) ---
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_DEVICE_CODE_URL=
OAUTH_CLIENT_ID=
OAUTH_SCOPES=

# --- OBO — On-Behalf-Of (AUTO — same app as above, single-app model) ---
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=
OBO_SCOPE=https://graph.microsoft.com/.default

# --- Session / Timeout ---
MCP_SESSION_TOKEN_TTL_SECONDS=3600
OAUTH_TIMEOUT_SECONDS=900

# --- Production APIM outputs (AUTO — set by deploy.ps1) ---
APIM_NAME=
APIM_GATEWAY=
MCP_ENDPOINT=
PRM_METADATA=
BACKEND_URL=
JWT_AUDIENCE=
JWT_ISSUER=
